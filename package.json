{
  "name": "flexi-ui",
  "version": "1.0.0",
  "license": "MIT",
  "description": "",
  "main": "index.js",
  "private": "true",
  "keywords": [],
  "author": {
    "name": "Muneeb Mughal",
    "email": "muneeb.it.dev@gmail.com",
    "url": "https://github.com/Muneeb-Mughal-Dev"
  },
  "scripts": {
    "prepare": "husky",
    "dev": "storybook dev -p 6006",
    "dev:docs": "npx nx run @flexi-ui/docs:dev",
    "dev:storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build -o storybook-static",
    "build": "npx nx run-many --target=build --all",
    "build:docs": "npx nx run @flexi-ui/docs:build",
    "lint": "eslint . --ext .ts,.js",
    "lint:fix": "eslint . --ext .ts,.js --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "typecheck": "npx nx run-many --target=typecheck --all",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "npx nx run-many --target=clean --all && rm -rf node_modules .nx pnpm-lock.yaml",
    "clean:cache": "rm -rf .nx node_modules/.cache",
    "changeset:add": "npx changeset add",
    "changeset:version": "npx changeset version",
    "changeset:release": "npx changeset publish",
    "changeset:beta": "changeset pre enter beta",
    "changeset:empty": "npx changeset add --empty"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.0",
    "@flexi-ui/standard": "workspace:*",
    "@flexi-ui/styles": "workspace:*",
    "@changesets/cli": "^2.27.11",
    "@changesets/get-github-info": "^0.6.0",
    "@changesets/get-release-plan": "^4.0.6",
    "@changesets/types": "^6.0.0",
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@eslint/js": "^9.17.0",
    "@flexi-ui/vitest": "workspace:*",
    "@storybook/addon-a11y": "^8.6.18",
    "@storybook/addon-essentials": "^8.6.18",
    "@storybook/react": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@tailwindcss/vite": "^4.1.12",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@vitest/coverage-istanbul": "^3.2.1",
    "@types/node": "catalog:",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "storybook": "^8.6.18",
    "tailwindcss": "^4.1.12",
    "vitest": "^3.2.1",
    "lint-staged": "^16.2.6",
    "nx": "^22.0.2",
    "prettier": "^3.4.2",
    "tsup": "^8.5.1",
    "tsx": "^4.19.2",
    "typescript": "catalog:",
    "typescript-eslint": "^8.19.0",
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:"
  },
  "pnpm": {
    "overrides": {
      "@changesets/get-github-info": "0.6.0"
    }
  },
  "engines": {
    "node": ">=22.x",
    "pnpm": ">=9.x"
  },
  "packageManager": "pnpm@9.6.0"
}
