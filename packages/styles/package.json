{
  "name": "@flexi-ui/styles",
  "version": "1.9.2",
  "description": "FlexiUI core styles and Tailwind CSS component library",
  "author": {
    "name": "Muneeb Mughal",
    "email": "muneeb.it.dev@gmail.com"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "style": "./dist/index.css",
  "exports": {
    ".": {
      "style": "./dist/index.css",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./css": {
      "style": "./dist/index.css",
      "default": "./dist/index.css"
    },
    "./components/*": {
      "types": "./dist/components/*/index.d.ts",
      "import": "./dist/components/*/index.js",
      "default": "./dist/components/*/index.js"
    },
    "./base/*.css": "./dist/base/*.css",
    "./components/*.css": "./dist/components/*.css",
    "./themes/*/*.css": "./dist/themes/*/*.css",
    "./themes/*.css": "./dist/themes/*.css",
    "./utilities/*.css": "./dist/utilities/*.css",
    "./variants/*.css": "./dist/variants/*.css",
    "./package.json": "./package.json"
  },
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json && node scripts/copy-css.mjs",
    "clean": "rm -rf dist .turbo tsconfig.tsbuildinfo",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "tailwind-variants": "^3.2.2"
  },
  "devDependencies": {
    "@flexi-ui/standard": "workspace:*",
    "tailwindcss": "^4.1.12",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "tailwindcss": ">=4.0.0"
  }
}
