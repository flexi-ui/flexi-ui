{
  "extends": "@flexi-ui/standard/tsconfig/next",
  "compilerOptions": {
    "target": "ES2017",
    "moduleDetection": "auto",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@/.source/*": ["./.source/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".source/**/*",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
