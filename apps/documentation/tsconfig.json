{
  "extends": "@flexi-ui/standard/tsconfig/next",
  "compilerOptions": {
    "target": "ES2017",
    "moduleDetection": "auto",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "contentlayer/generated": ["./.contentlayer/generated"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".contentlayer/generated",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
